# College Scorecard API (get a key at https://api.data.gov/signup/)
COLLEGESCORECARD_API_KEY=your_api_key_here

# NextAuth (required for sign-in)
NEXTAUTH_SECRET=your_random_secret_here
NEXTAUTH_URL=http://localhost:3001

# Optional: credentials for sign-in (if not set, sign-in will always fail)
# AUTH_EMAIL=admin@example.com
# AUTH_PASSWORD=your_password
